"""
Standalone memory extraction test harness.
Tests the extraction pipeline against real session data without touching the main codebase.
"""

import json
import asyncio
from datetime import datetime
from pathlib import Path
from typing import Any
import sys

# Add the nanobot path so we can import providers
sys.path.insert(0, '/data/projects/nanobot')

from nanobot.providers.registry import get_provider
from nanobot.session.manager import SessionManager


class ExtractionTestHarness:
    """Test harness for memory extraction pipeline."""
    
    def __init__(self):
        self.llm = get_provider('claude-opus')  # Use Opus for complex extraction decisions
        self.session_mgr = SessionManager()
        
    async def load_session_messages(self, session_key: str, limit: int = 25) -> list[dict]:
        """Load the last N messages from a session JSONL."""
        session_dir = Path.home() / '.nanobot' / 'workspace' / 'agents' / 'nanobot-dev' / 'sessions'
        jsonl_path = session_dir / f'{session_key}.jsonl'
        
        if not jsonl_path.exists():
            raise FileNotFoundError(f"Session JSONL not found: {jsonl_path}")
        
        messages = []
        with open(jsonl_path) as f:
            for line in f:
                messages.append(json.loads(line))
        
        # Return last N
        return messages[-limit:]
    
